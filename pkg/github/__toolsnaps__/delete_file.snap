{
  "annotations": {
    "destructiveHint": true,
    "title": "Delete file"
  },
  "description": "Delete a file from a GitHub repository",
  "inputSchema": {
    "properties": {
      "branch": {
        "description": "Branch to delete the file from",
        "type": "string"
      },
      "message": {
        "description": "Commit message",
        "type": "string"
      },
      "owner": {
        "description": "Repository owner (username or organization)",
        "type": "string"
      },
      "path": {
        "description": "Path to the file to delete",
        "type": "string"
      },
      "repo": {
        "description": "Repository name",
        "type": "string"
      }
    },
    "required": [
      "owner",
      "repo",
      "path",
      "message",
      "branch"
    ],
    "type": "object"
  },
  "name": "delete_file",
  "outputSchema": {
    "properties": {
      "commit": {
        "properties": {
          "author": {
            "properties": {
              "date": {
                "type": "string"
              },
              "email": {
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "message": {
            "type": "string"
          },
          "sha": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "content": {
        "type": "null"
      }
    },
    "type": "object"
  }
}