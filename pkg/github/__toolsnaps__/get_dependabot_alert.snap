{
  "annotations": {
    "readOnlyHint": true,
    "title": "Get dependabot alert"
  },
  "description": "Get details of a specific dependabot alert in a GitHub repository.",
  "inputSchema": {
    "properties": {
      "alertNumber": {
        "description": "The number of the alert.",
        "type": "number"
      },
      "owner": {
        "description": "The owner of the repository.",
        "type": "string"
      },
      "repo": {
        "description": "The name of the repository.",
        "type": "string"
      }
    },
    "required": [
      "owner",
      "repo",
      "alertNumber"
    ],
    "type": "object"
  },
  "name": "get_dependabot_alert",
  "outputSchema": {
    "properties": {
      "dependency": {
        "properties": {
          "package": {
            "properties": {
              "ecosystem": {
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            },
            "type": "object"
          }
        },
        "type": "object"
      },
      "html_url": {
        "type": "string"
      },
      "number": {
        "type": "integer"
      },
      "security_advisory": {
        "properties": {
          "cve_id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "ghsa_id": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "severity": {
        "type": "string"
      },
      "state": {
        "type": "string"
      }
    },
    "type": "object"
  }
}