{
  "annotations": {
    "readOnlyHint": true,
    "title": "List dependabot alerts"
  },
  "description": "List dependabot alerts in a GitHub repository.",
  "inputSchema": {
    "properties": {
      "owner": {
        "description": "The owner of the repository.",
        "type": "string"
      },
      "repo": {
        "description": "The name of the repository.",
        "type": "string"
      },
      "severity": {
        "description": "Filter dependabot alerts by severity",
        "enum": [
          "low",
          "medium",
          "high",
          "critical"
        ],
        "type": "string"
      },
      "state": {
        "default": "open",
        "description": "Filter dependabot alerts by state. Defaults to open",
        "enum": [
          "open",
          "fixed",
          "dismissed",
          "auto_dismissed"
        ],
        "type": "string"
      }
    },
    "required": [
      "owner",
      "repo"
    ],
    "type": "object"
  },
  "name": "list_dependabot_alerts",
  "outputSchema": {
    "properties": {
      "alerts": {
        "items": {
          "properties": {
            "dependency": {
              "properties": {
                "package": {
                  "properties": {
                    "ecosystem": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              },
              "type": "object"
            },
            "html_url": {
              "type": "string"
            },
            "number": {
              "type": "integer"
            },
            "security_advisory": {
              "properties": {
                "cve_id": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "ghsa_id": {
                  "type": "string"
                },
                "severity": {
                  "type": "string"
                },
                "summary": {
                  "type": "string"
                }
              },
              "type": "object"
            },
            "severity": {
              "type": "string"
            },
            "state": {
              "type": "string"
            }
          },
          "type": "object"
        },
        "type": "array"
      }
    },
    "type": "object"
  }
}