{
  "annotations": {
    "readOnlyHint": true,
    "title": "List discussion categories"
  },
  "description": "List discussion categories with their id and name, for a repository or organisation.",
  "inputSchema": {
    "properties": {
      "owner": {
        "description": "Repository owner",
        "type": "string"
      },
      "repo": {
        "description": "Repository name. If not provided, discussion categories will be queried at the organisation level.",
        "type": "string"
      }
    },
    "required": [
      "owner"
    ],
    "type": "object"
  },
  "name": "list_discussion_categories",
  "outputSchema": {
    "properties": {
      "categories": {
        "items": {
          "properties": {
            "id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            }
          },
          "type": "object"
        },
        "type": "array"
      },
      "pageInfo": {
        "properties": {
          "endCursor": {
            "type": "string"
          },
          "hasNextPage": {
            "type": "boolean"
          },
          "hasPreviousPage": {
            "type": "boolean"
          },
          "startCursor": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "totalCount": {
        "type": "integer"
      }
    },
    "type": "object"
  }
}