{
  "annotations": {
    "readOnlyHint": true,
    "title": "List tags"
  },
  "description": "List git tags in a GitHub repository",
  "inputSchema": {
    "properties": {
      "owner": {
        "description": "Repository owner",
        "type": "string"
      },
      "page": {
        "description": "Page number for pagination (min 1)",
        "minimum": 1,
        "type": "number"
      },
      "perPage": {
        "description": "Results per page for pagination (min 1, max 100)",
        "maximum": 100,
        "minimum": 1,
        "type": "number"
      },
      "repo": {
        "description": "Repository name",
        "type": "string"
      }
    },
    "required": [
      "owner",
      "repo"
    ],
    "type": "object"
  },
  "name": "list_tags",
  "outputSchema": {
    "properties": {
      "tags": {
        "items": {
          "properties": {
            "commit": {
              "properties": {
                "author": {
                  "properties": {
                    "date": {
                      "type": "string"
                    },
                    "email": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "username": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                },
                "comment_count": {
                  "type": "integer"
                },
                "committer": {
                  "properties": {
                    "date": {
                      "type": "string"
                    },
                    "email": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "username": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                },
                "html_url": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                },
                "node_id": {
                  "type": "string"
                },
                "parents": {
                  "items": {
                    "type": "object"
                  },
                  "type": "array"
                },
                "sha": {
                  "type": "string"
                },
                "tree": {
                  "type": "object"
                },
                "url": {
                  "type": "string"
                },
                "verification": {
                  "properties": {
                    "payload": {
                      "type": "string"
                    },
                    "reason": {
                      "type": "string"
                    },
                    "signature": {
                      "type": "string"
                    },
                    "verified": {
                      "type": "boolean"
                    }
                  },
                  "type": "object"
                }
              },
              "type": "object"
            },
            "name": {
              "type": "string"
            },
            "node_id": {
              "type": "string"
            },
            "tarball_url": {
              "type": "string"
            },
            "zipball_url": {
              "type": "string"
            }
          },
          "type": "object"
        },
        "type": "array"
      }
    },
    "type": "object"
  }
}