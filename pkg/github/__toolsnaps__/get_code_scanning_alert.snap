{
  "annotations": {
    "readOnlyHint": true,
    "title": "Get code scanning alert"
  },
  "description": "Get details of a specific code scanning alert in a GitHub repository.",
  "inputSchema": {
    "properties": {
      "alertNumber": {
        "description": "The number of the alert.",
        "type": "number"
      },
      "owner": {
        "description": "The owner of the repository.",
        "type": "string"
      },
      "repo": {
        "description": "The name of the repository.",
        "type": "string"
      }
    },
    "required": [
      "owner",
      "repo",
      "alertNumber"
    ],
    "type": "object"
  },
  "name": "get_code_scanning_alert",
  "outputSchema": {
    "properties": {
      "html_url": {
        "type": "string"
      },
      "number": {
        "type": "integer"
      },
      "rule": {
        "properties": {
          "description": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "state": {
        "type": "string"
      }
    },
    "type": "object"
  }
}