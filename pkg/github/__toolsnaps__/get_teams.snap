{
  "annotations": {
    "readOnlyHint": true,
    "title": "Get teams"
  },
  "description": "Get details of the teams the user is a member of. Limited to organizations accessible with current credentials",
  "inputSchema": {
    "properties": {
      "user": {
        "description": "Username to get teams for. If not provided, uses the authenticated user.",
        "type": "string"
      }
    },
    "type": "object"
  },
  "name": "get_teams",
  "outputSchema": {
    "properties": {
      "organizations": {
        "items": {
          "properties": {
            "org": {
              "type": "string"
            },
            "teams": {
              "items": {
                "properties": {
                  "description": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "slug": {
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "type": "array"
            }
          },
          "type": "object"
        },
        "type": "array"
      }
    },
    "type": "object"
  }
}